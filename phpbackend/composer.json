{
    "name": "configflow-php-backend",
    "description": "ConfigFlow PHP Backend API with MySQL - PHP 7.4 compatible",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "slim/slim": "^4.0",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^6.4",
        "firebase/php-jwt": "^6.0",
        "vlucas/phpdotenv": "^5.5",
        "monolog/monolog": "^2.9",
        "ext-pdo": "*",
        "ext-json": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "start": "php -S 0.0.0.0:8080 -t public",
        "migrate": "php bin/migrate.php",
        "seed": "php bin/seed.php"
    }
}
