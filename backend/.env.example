# ===== SERVER =====
PORT=4000
NODE_ENV=development

# ===== DATABASE =====
# Switch between "pg" and "mysql2"
DB_CLIENT=pg

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_pg_password
PG_DATABASE=configflow

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=configflow

# ===== AUTH =====
JWT_SECRET=change-this-to-a-long-random-string-min-64-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=another-long-random-string

# ===== SECURITY =====
CSRF_SECRET=csrf-random-secret-key
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
MAX_LOGIN_ATTEMPTS=5
LOCK_DURATION_MINUTES=30
PASSWORD_MIN_LENGTH=12
SESSION_MAX_AGE_MS=3600000
